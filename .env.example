# Persistence (Upstash Redis / Vercel KV).
#
# LOCAL DEV: leave these unset — the app falls back to the data/site.json file.
# VERCEL:    add the Upstash (Marketplace) or Vercel KV integration and these
#            are injected automatically. Either variable pair works.

# Vercel KV names:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ...or Upstash names (only one pair is needed):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
